// examples/generics.omni
// Testing Phase 2 Built-in List<T>

class Main {
    public function main() {
        var list = new List<Int>();
        list.add(10);
        list.add(20);
        list.add(30);

        print("List size is:");
        print(list.size());

        print("Element at index 1:");
        print(list.get(1));
    }
}
